<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Crazy Profile</title>

<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:Poppins, sans-serif;
}

body{
height:100vh;
display:flex;
justify-content:center;
align-items:center;
background:linear-gradient(-45deg,#0f2027,#203a43,#2c5364,#000000);
background-size:400% 400%;
animation:bg 12s ease infinite;
perspective:1000px;
color:white;
}

@keyframes bg{
0%{background-position:0% 50%}
50%{background-position:100% 50%}
100%{background-position:0% 50%}
}

/* 3D card */

.card{
width:320px;
padding:40px;
text-align:center;
border-radius:25px;
background:rgba(255,255,255,0.05);
backdrop-filter:blur(15px);
box-shadow:0 20px 60px rgba(0,0,0,0.8);
transform-style:preserve-3d;
transition:0.6s;
}

.card:hover{
transform:rotateY(10deg) rotateX(5deg) scale(1.05);
}

/* neon border */

.card::before{
content:"";
position:absolute;
inset:-2px;
border-radius:25px;
background:linear-gradient(45deg,#00ffff,#ff00ff,#00ffff);
filter:blur(8px);
z-index:-1;
}

/* profile pic */

.pfp{
width:130px;
height:130px;
border-radius:50%;
border:3px solid cyan;
box-shadow:0 0 25px cyan;
margin-bottom:20px;
transition:0.4s;
}

.pfp:hover{
transform:scale(1.15);
box-shadow:0 0 50px cyan;
}

/* name */

.name{
font-size:30px;
letter-spacing:5px;
text-shadow:0 0 20px cyan;
margin-bottom:25px;
}

/* button */

.btn{
display:inline-block;
padding:12px 28px;
border-radius:30px;
background:linear-gradient(45deg,#00c6ff,#0072ff);
text-decoration:none;
color:white;
font-weight:bold;
box-shadow:0 10px 30px rgba(0,0,0,0.6);
transition:0.3s;
}

.btn:hover{
transform:translateY(-5px) scale(1.1);
box-shadow:0 0 25px cyan;
}

</style>
</head>

<body>

<audio autoplay>
<source src="crazy.mp3" type="audio/mpeg">
</audio>

<div class="card">

<img class="pfp" src="https://i.supaimg.com/20a17276-cffe-43a3-9acb-1773af708080/458d1d29-475b-4f13-9115-89bb7a8eea24.jpg">

<div class="name">CRAZY</div>

<a class="btn" href="https://t.me/Piroskemer">JOIN TELEGRAM</a>

</div>

</body>
</html>

